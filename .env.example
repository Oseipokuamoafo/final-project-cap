# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will NOT be committed.

# ── LLM for AI-generated summaries (pick one) ─────────────────────────────────
# Option 1 — Groq (FREE, no credit card required)
# Sign up at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Option 2 — Anthropic Claude (paid, falls back if Groq key is absent)
# Sign up at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Last.fm for real song data (FREE, no OAuth required) ──────────────────────
# Sign up at: https://www.last.fm/api/account/create
# Used by src/lastfm_client.py to fetch real tracks by genre and similar songs.
LASTFM_API_KEY=your_lastfm_api_key_here

# ── Logging ────────────────────────────────────────────────────────────────────
# Optional: set to DEBUG for verbose logs, WARNING to suppress info messages
LOG_LEVEL=INFO
